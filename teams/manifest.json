{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.1.0",
  "id": "ae69cff7-9f5a-4a0f-bc4d-fbe4019007d3",
  "packageName": "com.alan.englishlearning.livetranslator",
  "developer": {
    "name": "Alan",
    "websiteUrl": "https://alan765477.github.io/English-Learning-/",
    "privacyUrl": "https://alan765477.github.io/English-Learning-/",
    "termsOfUseUrl": "https://alan765477.github.io/English-Learning-/"
  },
  "name": {
    "short": "实时翻译",
    "full": "会议实时翻译 · Live Meeting Translator"
  },
  "description": {
    "short": "开会时英↔中双向实时翻译字幕",
    "full": "在 Teams 会议侧边栏显示实时翻译字幕：捕获会议声音或麦克风，英语发言译成中文、中文发言译成英文，支持双向自动识别，边说边出字幕。API Key 只保存在本机浏览器，纯前端实现，无服务器。"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#4F46E5",
  "configurableTabs": [
    {
      "configurationUrl": "https://alan765477.github.io/English-Learning-/teams-config.html",
      "canUpdateConfiguration": false,
      "scopes": ["groupChat"],
      "context": ["meetingSidePanel", "meetingChatTab", "meetingDetailsTab"]
    }
  ],
  "staticTabs": [
    {
      "entityId": "live-translator-personal",
      "name": "实时翻译",
      "contentUrl": "https://alan765477.github.io/English-Learning-/teams.html",
      "websiteUrl": "https://alan765477.github.io/English-Learning-/teams.html",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity"],
  "devicePermissions": ["media"],
  "validDomains": ["alan765477.github.io"]
}
